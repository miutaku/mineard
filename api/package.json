{
  "name": "mineard-api",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create mineard",
    "db:migrate": "wrangler d1 execute mineard --file=src/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute mineard --local --file=src/db/schema.sql"
  },
  "dependencies": {
    "hono": "^4.12.23",
    "otpauth": "^9.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260530.1",
    "typescript": "^6.0.0",
    "wrangler": "^4.95.0"
  }
}
